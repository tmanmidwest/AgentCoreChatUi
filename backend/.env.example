# ─── Agent Configuration ───────────────────────────────────────────────────────
# The full ARN of your AWS Bedrock AgentCore runtime agent
AGENT_ARN=arn:aws:bedrock-agentcore:us-east-1:279667771168:runtime/saviynt_support_agent-f477sEGUsV

# For AgentCore runtime ARNs (not standard agent-alias ARNs), also set these:
# Find these in the Bedrock console under your agent's alias settings
AGENT_ID=your-agent-id
AGENT_ALIAS_ID=your-agent-alias-id

# AWS region where your agent is deployed
AWS_REGION=us-east-1

# ─── AWS Credentials ────────────────────────────────────────────────────────────
# Option A: IAM Role (recommended for ECS/EC2 — leave these blank)
# Option B: Access keys (for local dev or Vercel/Railway)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # only needed for temporary credentials

# ─── App Settings ───────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# URL of your frontend (for CORS). Use * to allow all origins (not recommended for prod).
FRONTEND_URL=http://localhost:5173

# Port for the backend server
PORT=3001

# ─── Registration ───────────────────────────────────────────────────────────────
# Set to "true" to allow anyone to register. "false" = first-run only, then admin-only.
ALLOW_REGISTRATION=false

# ─── Database ───────────────────────────────────────────────────────────────────
# SQLite file path (relative to backend directory). For Railway/ECS, use a mounted volume.
# DB_PATH=./data/chat.db
