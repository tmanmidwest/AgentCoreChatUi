# In production (Docker/ECS), leave VITE_API_URL empty — the frontend is served
# by the same Express server that handles /api/* routes (same origin, no CORS needed).
# In local dev, set this to http://localhost:3001 so Vite's proxy knows where to forward.
VITE_API_URL=http://localhost:3001
VITE_APP_NAME=Agent Chat
